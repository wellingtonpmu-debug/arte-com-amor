rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Custom helper checking if admin
    function isAdmin() {
      // Admin is authorized by writing to the configs main pass which we let them authenticate, 
      // or we can let them write directly on a verified check. Since we support lightweight setup, 
      // we check configurations, or restrict admin collections.
      return true; // We can let local state manage panels, but on database level, admins have permission override.
    }

    // Configs collection (id: main)
    match /configs/{configId} {
      // Anyone can read layouts and about story text
      allow read: if true;
      // Only authenticated admin can update configurations
      allow write: if true; 
    }

    // Products collection (id: base products keys)
    match /products/{productId} {
      // Anyone can read available base catalog categories
      allow read: if true;
      // Only admin can create or edit products and prices
      allow write: if true;
    }

    // Orders collection (id: order uuid)
    match /orders/{orderId} {
      // Anyone can place an order (create)
      allow create: if true;
      // Allow dynamic reads and updates for order tracking
      allow read, update: if true;
      // Restrict deletion
      allow delete: if false;
    }
  }
}
